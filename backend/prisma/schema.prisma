generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model apartment {
  id                                       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  house_id                                 String?       @db.Uuid
  created_at                               DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime?     @default(now()) @db.Timestamptz(6)
  name                                     String        @db.VarChar(50)
  house                                    house?        @relation(fields: [house_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  birth_place                              birth_place[]
  residence_residence_apartmentToapartment residence[]   @relation("residence_apartmentToapartment")
}

model city {
  id                             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  region_id                      String?       @db.Uuid
  name                           String?       @db.VarChar(150)
  created_at                     DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime?     @default(now()) @db.Timestamptz(6)
  birth_place                    birth_place[]
  region                         region?       @relation(fields: [region_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  death_place                    death_place[]
  residence_residence_cityTocity residence[]   @relation("residence_cityTocity")
  street                         street[]

  @@unique([region_id, name])
}

model country {
  id                                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                 String?       @unique @db.VarChar(100)
  created_at                           DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime?     @default(now()) @db.Timestamptz(6)
  birth_place                          birth_place[]
  death_place                          death_place[]
  region                               region[]
  residence_residence_countryTocountry residence[]   @relation("residence_countryTocountry")
}

model education {
  id                                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institution                        String?   @db.VarChar(200)
  degree                             String?   @db.VarChar(100)
  specialty                          String?   @db.VarChar(150)
  year_start                         Int?
  year_end                           Int?
  created_at                         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime? @default(now()) @db.Timestamptz(6)
  person_person_educationToeducation person[]  @relation("person_educationToeducation")
}

model geneology_tree {
  id                           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                         String    @db.VarChar(300)
  count_all_characters         Int?      @default(0)
  count_all_characters_alive   Int?      @default(0)
  count_all_characters_dead    Int?      @default(0)
  count_all_characters_kids    Int?      @default(0)
  count_all_characters_parents Int?      @default(0)
  count_all_characters_male    Int?      @default(0)
  count_all_characters_female  Int?      @default(0)
  created_at                   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime? @default(now()) @db.Timestamptz(6)
  person                       person[]
}

model house {
  id                               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  street_id                        String?       @db.Uuid
  created_at                       DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime?     @default(now()) @db.Timestamptz(6)
  name                             String        @db.VarChar(50)
  apartment                        apartment[]
  birth_place                      birth_place[]
  street                           street?       @relation(fields: [street_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  residence_residence_houseTohouse residence[]   @relation("residence_houseTohouse")
}

model maiden_surname {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String?   @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  person     person[]
}

model nationality {
  id                                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                   String?   @unique @db.VarChar(100)
  created_at                             DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime? @default(now()) @db.Timestamptz(6)
  person_person_nationalityTonationality person[]  @relation("person_nationalityTonationality")
}

model occupation {
  id                                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                                String?   @db.VarChar(150)
  organization                         String?   @db.VarChar(200)
  start_year                           Int?
  end_year                             Int?
  created_at                           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime? @default(now()) @db.Timestamptz(6)
  person_person_occupationTooccupation person[]  @relation("person_occupationTooccupation")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model person {
  id                                          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  genealogy_tree_id                           String?              @db.Uuid
  mother                                      String?              @db.Uuid
  father                                      String?              @db.Uuid
  marital_status                              marriage_status_type @default(single)
  spouse                                      String?              @db.Uuid
  surname                                     String?              @db.Uuid
  maidensurname                               String?              @db.Uuid
  firstname                                   String               @db.VarChar(100)
  patronymic                                  String?              @db.VarChar(100)
  fullname                                    String?              @db.VarChar(300)
  age                                         Int
  gender                                      gender_status
  occupation                                  String?              @db.Uuid
  education                                   String?              @db.Uuid
  fulladdress                                 String?              @db.VarChar(1000)
  cityaddress                                 String?              @db.VarChar(800)
  residence                                   String?              @db.Uuid
  nationality                                 String?              @db.Uuid
  socialstatus                                String?              @db.Uuid
  birth_place                                 String?              @db.Uuid
  death_place                                 String?              @db.Uuid
  bio                                         String?
  source_info                                 String?
  ispersoncontacted                           Boolean?             @default(false)
  isalive                                     Boolean?
  created_at                                  DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                                  DateTime?            @default(now()) @db.Timestamptz(6)
  birth_place_person_birth_placeTobirth_place birth_place?         @relation("person_birth_placeTobirth_place", fields: [birth_place], references: [id], onDelete: NoAction, onUpdate: NoAction)
  death_place_person_death_placeTodeath_place death_place?         @relation("person_death_placeTodeath_place", fields: [death_place], references: [id], onDelete: NoAction, onUpdate: NoAction)
  education_person_educationToeducation       education?           @relation("person_educationToeducation", fields: [education], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_person_fatherToperson                person?              @relation("person_fatherToperson", fields: [father], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_person_person_fatherToperson          person[]             @relation("person_fatherToperson")
  geneology_tree                              geneology_tree?      @relation(fields: [genealogy_tree_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  maiden_surname                              maiden_surname?      @relation(fields: [maidensurname], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_person_motherToperson                person?              @relation("person_motherToperson", fields: [mother], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_person_person_motherToperson          person[]             @relation("person_motherToperson")
  nationality_person_nationalityTonationality nationality?         @relation("person_nationalityTonationality", fields: [nationality], references: [id], onDelete: NoAction, onUpdate: NoAction)
  occupation_person_occupationTooccupation    occupation?          @relation("person_occupationTooccupation", fields: [occupation], references: [id], onDelete: NoAction, onUpdate: NoAction)
  residence_person_residenceToresidence       residence?           @relation("person_residenceToresidence", fields: [residence], references: [id], onDelete: NoAction, onUpdate: NoAction)
  social_status                               social_status?       @relation(fields: [socialstatus], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_person_spouseToperson                person?              @relation("person_spouseToperson", fields: [spouse], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_person_person_spouseToperson          person[]             @relation("person_spouseToperson")
  surname_person_surnameTosurname             surname?             @relation("person_surnameTosurname", fields: [surname], references: [id], onDelete: NoAction, onUpdate: NoAction)
  relations_relations_fatheridToperson        relations[]          @relation("relations_fatheridToperson")
  relations_relations_motheridToperson        relations[]          @relation("relations_motheridToperson")
  relations_relations_personidToperson        relations[]          @relation("relations_personidToperson")
  relations_relations_spouseidToperson        relations[]          @relation("relations_spouseidToperson")

  @@index([cityaddress], map: "idx_person_cityaddress")
  @@index([fullname], map: "idx_person_fullname")
}

model region {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country_id String?   @db.Uuid
  name       String?   @unique @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  city       city[]
  country    country?  @relation(fields: [country_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([country_id, name])
}

model residence {
  id                                       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  country                                  String?    @db.Uuid
  city                                     String?    @db.Uuid
  street                                   String?    @db.Uuid
  house                                    String?    @db.Uuid
  apartment                                String?    @db.Uuid
  start_date                               DateTime?  @db.Date
  end_date                                 DateTime?  @db.Date
  start_date_approx                        Boolean?   @default(false)
  end_date_approx                          Boolean?   @default(false)
  created_at                               DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime?  @default(now()) @db.Timestamptz(6)
  person_person_residenceToresidence       person[]   @relation("person_residenceToresidence")
  apartment_residence_apartmentToapartment apartment? @relation("residence_apartmentToapartment", fields: [apartment], references: [id], onDelete: NoAction, onUpdate: NoAction)
  city_residence_cityTocity                city?      @relation("residence_cityTocity", fields: [city], references: [id], onDelete: NoAction, onUpdate: NoAction)
  country_residence_countryTocountry       country?   @relation("residence_countryTocountry", fields: [country], references: [id], onDelete: NoAction, onUpdate: NoAction)
  house_residence_houseTohouse             house?     @relation("residence_houseTohouse", fields: [house], references: [id], onDelete: NoAction, onUpdate: NoAction)
  street_residence_streetTostreet          street?    @relation("residence_streetTostreet", fields: [street], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model social_status {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String?   @unique @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  person      person[]
}

model street {
  id                                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  city_id                            String?       @db.Uuid
  created_at                         DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime?     @default(now()) @db.Timestamptz(6)
  name                               String        @db.VarChar(200)
  birth_place                        birth_place[]
  house                              house[]
  residence_residence_streetTostreet residence[]   @relation("residence_streetTostreet")
  city                               city?         @relation(fields: [city_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model surname {
  id                             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                           String?   @db.VarChar(100)
  created_at                     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime? @default(now()) @db.Timestamptz(6)
  person_person_surnameTosurname person[]  @relation("person_surnameTosurname")
}

model birth_place {
  id                                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  birth_date                             DateTime?  @db.Date
  birth_date_approx                      Boolean?   @default(false)
  birth_place_country_id                 String?    @db.Uuid
  birth_place_city_id                    String?    @db.Uuid
  birth_place_street                     String?    @db.Uuid
  birth_place_house                      String?    @db.Uuid
  birth_place_apartment                  String?    @db.Uuid
  created_at                             DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?  @default(now()) @db.Timestamptz(6)
  apartment                              apartment? @relation(fields: [birth_place_apartment], references: [id], onDelete: NoAction, onUpdate: NoAction)
  city                                   city?      @relation(fields: [birth_place_city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  country                                country?   @relation(fields: [birth_place_country_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  house                                  house?     @relation(fields: [birth_place_house], references: [id], onDelete: NoAction, onUpdate: NoAction)
  street                                 street?    @relation(fields: [birth_place_street], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_person_birth_placeTobirth_place person[]   @relation("person_birth_placeTobirth_place")
}

model death_place {
  id                                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  death_date                             DateTime? @db.Date
  death_date_approx                      Boolean?  @default(false)
  death_place_country_id                 String?   @db.Uuid
  death_place_city_id                    String?   @db.Uuid
  created_at                             DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime? @default(now()) @db.Timestamptz(6)
  city                                   city?     @relation(fields: [death_place_city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  country                                country?  @relation(fields: [death_place_country_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_person_death_placeTodeath_place person[]  @relation("person_death_placeTodeath_place")
}

model relations {
  id                                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fatherid                          String?   @db.Uuid
  motherid                          String?   @db.Uuid
  personid                          String?   @db.Uuid
  spouseid                          String?   @db.Uuid
  autonaming                        String?   @db.VarChar(50)
  created_at                        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime? @default(now()) @db.Timestamptz(6)
  person_relations_fatheridToperson person?   @relation("relations_fatheridToperson", fields: [fatherid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_relations_motheridToperson person?   @relation("relations_motheridToperson", fields: [motherid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_relations_personidToperson person?   @relation("relations_personidToperson", fields: [personid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  person_relations_spouseidToperson person?   @relation("relations_spouseidToperson", fields: [spouseid], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([fatherid, motherid, personid, spouseid])
}

enum gender_status {
  male
  female
}

enum marriage_status_type {
  divorced
  single
  widowed
  married
}
